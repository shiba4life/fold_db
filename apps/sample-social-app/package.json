{
  "name": "sample-social-app",
  "version": "1.0.0",
  "description": "Sample social app for Datafold",
  "main": "index.html",
  "scripts": {
    "test": "node test-runner.js",
    "test:headless": "node test-runner.js --headless",
    "test:navigation": "node test-runner.js --suite=navigation",
    "test:post": "node test-runner.js --suite=post",
    "test:profile": "node test-runner.js --suite=profile",
    "test:friend": "node test-runner.js --suite=friend",
    "test:single": "node run-single-test.js",
    "test:api": "node run-api-tests.js",
    "test:api:verbose": "node run-api-tests.js --verbose",
    "test:folddb": "node test-folddb.js",
    "test:folddb:verbose": "node test-folddb.js --verbose",
    "test:integration": "node run-integration-tests.js",
    "test:integration:verbose": "node run-integration-tests.js --verbose",
    "test:integration:headless": "node run-integration-tests.js --headless",
    "test:integration:datafold": "node run-integration-tests-with-datafold.js",
    "test:integration:datafold:verbose": "node run-integration-tests-with-datafold.js --verbose",
    "test:integration:datafold:headless": "node run-integration-tests-with-datafold.js --headless",
    "serve": "serve .",
    "server": "node server.js"
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "puppeteer": "^22.8.2",
    "serve": "^14.2.0",
    "serve-handler": "^6.1.5"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "private": true
}
